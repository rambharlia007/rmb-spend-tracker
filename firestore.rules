rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(wsId) {
      return isSignedIn() &&
        get(/databases/$(db)/documents/workspaces/$(wsId)).data.members.hasAny([request.auth.uid]);
    }

    // Global users table:
    // - Any signed-in user can READ (needed for email-based contact lookup)
    // - Any signed-in user can CREATE (needed to create stubs for non-registered contacts)
    // - Only the doc owner (matched by googleUid field) can UPDATE/DELETE their own doc
    match /users/{internalId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        (resource.data.googleUid == request.auth.uid ||
         resource.data.googleUid == null);

      // contacts and contactInvites paths now use internalId (stable FK) as the parent doc ID.
      // Ownership check: the user doc at this internalId must have googleUid == caller's auth uid.
      // Anyone signed-in can create contactInvites (needed to send invites to others).
      match /contacts/{contactId} {
        allow read, write: if isSignedIn() &&
          get(/databases/$(db)/documents/users/$(internalId)).data.googleUid == request.auth.uid;
      }

      match /contactInvites/{id} {
        allow create: if isSignedIn();
        allow read, update, delete: if isSignedIn() &&
          get(/databases/$(db)/documents/users/$(internalId)).data.googleUid == request.auth.uid;
      }
    }

    // Workspaces — members identified by internalId stored in members array
    // workspace ownerInternalId and members store internalId
    match /workspaces/{wsId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      match /categories/{id} {
        allow read, write: if isSignedIn();
      }
      match /paymentSources/{id} {
        allow read, write: if isSignedIn();
      }
      match /spends/{id} {
        allow read, write: if isSignedIn();
      }
      match /notes/{id} {
        allow read, write: if isSignedIn();
      }
      match /invites/{id} {
        allow read, write: if isSignedIn();
      }
    }

    // App-wide error logs — centralised, flat collection
    // Any signed-in user can write their own error docs.
    // Only the admin (identified by email on the user doc) can read all logs.
    // Since we can't query email directly in rules without a get(), we keep read open
    // to signed-in users and restrict in the UI (AdminLogs page hard-redirects non-admins).
    match /appLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // Shared loans — giver or receiver by internalId
    match /sharedLoans/{loanId} {
      function isGiverOrReceiver() {
        return isSignedIn() && (
          resource.data.giverInternalId == request.auth.uid ||
          resource.data.receiverInternalId == request.auth.uid
        );
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      match /repayments/{repId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
